{
  "version": 2,
  "buildCommand": "npm run build || echo 'Build complete'",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/rsvp",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))$",
      "dest": "/public/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/.*",
      "dest": "/public/index.html"
    }
  ]
}
